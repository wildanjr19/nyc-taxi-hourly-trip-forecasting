# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class

# Python packaging/build artifacts
*.egg-info/
.eggs/
build/
dist/
pip-wheel-metadata/
wheelhouse/

# Virtual environments
.venv/
venv/
env/
ENV/

# Test, lint, and coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
coverage.xml
htmlcov/

# Jupyter
.ipynb_checkpoints/

# Local environment and secrets
.env
.env.*
!.env.example

# Data files are local research inputs/derived splits.
# Keep README/.gitkeep placeholders trackable.
data/**
!data/
!data/**/
!data/**/.gitkeep
!data/**/README.md

# Generated experiment outputs.
# Markdown reports are allowed because they can be final research deliverables.
# outputs/**
# !outputs/
# !outputs/**/
# !outputs/**/.gitkeep
# !outputs/**/README.md
# !outputs/reports/
# !outputs/reports/**/*.md

# Model artifacts and checkpoints
/models/
/artifacts/
/checkpoints/
*.pkl
*.pickle
*.joblib
*.model
*.ubj

# Experiment trackers and runtime logs
mlruns/
wandb/
*.log

# Local IDE/editor files
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/

# OS-specific files
.DS_Store
Thumbs.db
Desktop.ini

# Temporary files
tmp/
temp/
*.tmp
*.bak

# vscode
.vscode/